{
  "name": "quick-stack",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev-live": "tsc --project tsconfig.server.json && tsc-alias -p tsconfig.server.json && node dist/server.js",
    "build": "next build && tsc --project tsconfig.server.json && tsc-alias -p tsconfig.server.json",
    "start": "next start",
    "start-prod": "cross-env NODE_ENV=production node dist/server.js",
    "prisma-generate": "npx prisma generate && node ./fix-wrong-zod-imports.js",
    "prisma-generate-build": "npx prisma generate && node ./fix-wrong-zod-imports.js",
    "prisma-migrate": "npx prisma migrate dev --name migration",
    "prisma-deploy": "npx prisma migrate deploy",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
